# ============================================================
# Keystore configuration for PiliPlus Android release builds.
# COPY this file to key.properties and fill in YOUR credentials.
#
# How to generate a keystore:
#   keytool -genkey -v -keystore release-key.jks -keyalg RSA \
#       -keysize 2048 -validity 10000 -alias upload
#
# Distribution:
#   - NEVER commit key.properties, .jks, or any password in git.
#   - .gitignore already excludes: **/android/key.properties, *.jks
# ============================================================

storeFile=release-key.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=upload
keyPassword=YOUR_KEY_PASSWORD
